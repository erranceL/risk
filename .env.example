PORT=8787
QUOTE_CADENCE_MS=100
QUOTE_TTL_MS=300
MAX_BODY_BYTES=1048576
DATABASE_URL=postgres://risk:password@localhost:5432/risk
# Bearer token for POST /events (main platform -> vendor). Empty = open (dev only).
RISK_EVENT_TOKEN=
# Bearer token for config + exposure snapshot endpoints. Empty = open (dev only).
RISK_CONTROL_TOKEN=
# Bearer token for reading quotes/exposure. Empty = open (dev only).
RISK_QUOTE_TOKEN=
# Safety switch: in production, empty auth tokens refuse startup unless this is true.
RISK_ALLOW_INSECURE_NO_AUTH=false
